{
  "name": "freecustom-email",
  "version": "1.0.2",
  "description": "Official TypeScript/JavaScript SDK for FreeCustom.Email — disposable inboxes, OTP extraction, real-time WebSocket delivery",
  "keywords": [
    "disposable-email",
    "temp-mail",
    "otp",
    "email-api",
    "freecustom",
    "temporary-email",
    "fake-email",
    "inbox"
  ],
  "homepage": "https://www.freecustom.email/en",
  "bugs": {
    "url": "https://github.com/dishis/fce-sdk-npm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fce-sdk-npm.git"
  },
  "license": "MIT",
  "author": "FreeCustom.Email <support@freecustom.email>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "module": "./dist/index.js"
}
